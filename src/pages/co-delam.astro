---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/site-config';
---

<BaseLayout
  title={`Co dělám | ${siteConfig.businessName}`}
  description="Přehled revizních služeb: elektroinstalace, hromosvody, spotřebiče, odběrná místa ČEZ, SVJ a pojišťovny."
>
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="font-heading text-3xl font-bold text-brand-dark sm:text-4xl">Co dělám</h1>
    <p class="mt-6 text-brand-secondary">
      Nabízím kompletní revizní služby v oblasti {siteConfig.serviceArea}. Níže je přehled toho, co
      nejčastěji revidujeme.
    </p>

    <dl class="mt-10 space-y-8">
      {
        siteConfig.services.map((service) => (
          <div class="border-b border-slate-200 pb-8">
            <dt class="font-heading text-xl font-semibold text-brand-dark">{service.title}</dt>
            <dd class="mt-2 text-brand-secondary">{service.description}</dd>
          </div>
        ))
      }
    </dl>
  </section>
</BaseLayout>
