---
import BaseLayout from '../layouts/BaseLayout.astro';
import { siteConfig } from '../lib/site-config';
---

<BaseLayout
  title={`O mně | ${siteConfig.businessName}`}
  description={`${siteConfig.ownerName} – revizní technik v oblasti ${siteConfig.serviceArea}.`}
>
  <section class="mx-auto max-w-3xl px-4 py-16 sm:px-6">
    <h1 class="font-heading text-3xl font-bold text-brand-dark sm:text-4xl">O mně</h1>
    <p class="mt-6 text-brand-secondary">
      Jsem {siteConfig.ownerName}, revizní technik zaměřený na bezpečnost elektrických zařízení,
      hromosvodů a spotřebičů. Provádím revize elektroinstalace a vyhotovuji revizní zprávy podle
      platných norem pro domácnosti, firmy i bytová družstva v oblasti {siteConfig.serviceArea}.
    </p>
    <p class="mt-4 text-brand-secondary">
      {/* TODO: doplnit podrobnější profesní životopis, certifikace a délku praxe */}
      Cílem je, aby revize proběhla rychle, srozumitelně a s jasným výstupem, na který se dá spolehnout
      při jednání s pojišťovnou, ČEZ, SVJ nebo při kolaudaci.
    </p>

    <div class="mt-10 rounded-lg border border-slate-200 p-6">
      <h2 class="font-heading text-lg font-semibold text-brand-dark">Provozní doba</h2>
      <ul class="mt-3 space-y-1 text-sm text-brand-secondary">
        <li>{siteConfig.openingHours.weekdays}</li>
        <li>{siteConfig.openingHours.saturday}</li>
      </ul>
    </div>
  </section>
</BaseLayout>
