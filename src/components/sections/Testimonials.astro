---
import StarRating from '../ui/StarRating.astro';
import { siteConfig } from '../../lib/site-config';

// Zdvojený seznam pro plynulou nekonečnou smyčku animace
const items = [...siteConfig.testimonials, ...siteConfig.testimonials];
---

<section class="overflow-hidden border-y border-slate-200 bg-slate-100 py-16">
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <h2 class="font-heading text-2xl font-bold text-brand-dark sm:text-3xl">Reference</h2>
    <p class="mt-2 max-w-2xl text-brand-secondary">Co o mně říkají spokojení zákazníci.</p>
    <a
      href={siteConfig.googleReviewUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="mt-4 inline-flex min-h-11 items-center rounded-md border border-brand-primary px-5 py-2.5 text-sm font-semibold text-brand-dark hover:bg-brand-primary/10"
    >
      Napsat recenzi na Google
    </a>
  </div>

  <div
    class="mt-10 [mask-image:linear-gradient(to_right,transparent,black_5%,black_95%,transparent)]"
  >
    <ul class="flex w-max gap-6 px-4 animate-marquee hover:[animation-play-state:paused]">
      {
        items.map((testimonial) => (
          <li class="w-80 shrink-0 rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <StarRating rating={testimonial.rating} />
            <p class="mt-3 text-sm text-brand-secondary">„{testimonial.text}“</p>
            <p class="mt-4 font-heading text-sm font-semibold text-brand-dark">
              {testimonial.name}
            </p>
          </li>
        ))
      }
    </ul>
  </div>
</section>
