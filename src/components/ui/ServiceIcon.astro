---
// Jednoduché zástupné ikony pro karty služeb – nahradit finálními ikonami od klienta
export type ServiceIconName =
  'wiring' | 'lightning-rod' | 'appliance' | 'meter' | 'building' | 'insurance';

interface Props {
  name: ServiceIconName;
  class?: string;
}

const { name, class: className } = Astro.props;
---

{
  name === 'wiring' && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={className}
      aria-hidden="true"
    >
      <path d="M9 2v5M15 2v5" />
      <rect x="6" y="7" width="12" height="8" rx="4" />
      <path d="M12 15v6" />
    </svg>
  )
}

{
  name === 'lightning-rod' && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={className}
      aria-hidden="true"
    >
      <path d="M9 6l3-3 3 3" />
      <path d="M12 3v18" />
      <path d="M8 21h8" />
    </svg>
  )
}

{
  name === 'appliance' && (
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class={className} aria-hidden="true">
      <circle cx="12" cy="12" r="9" stroke-width="1.5" />
      <path
        d="M8.5 12.5l2.5 2.5 5-5"
        stroke-width="1.5"
        stroke-linecap="round"
        stroke-linejoin="round"
      />
    </svg>
  )
}

{
  name === 'meter' && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={className}
      aria-hidden="true"
    >
      <path d="M4 16a8 8 0 0 1 16 0" />
      <path d="M12 16l4-5" />
      <circle cx="12" cy="16" r="1" fill="currentColor" stroke="none" />
    </svg>
  )
}

{
  name === 'building' && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={className}
      aria-hidden="true"
    >
      <rect x="5" y="3" width="14" height="18" rx="1" />
      <path d="M9 7h2M13 7h2M9 11h2M13 11h2M9 15h2M13 15h2" />
    </svg>
  )
}

{
  name === 'insurance' && (
    <svg
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="1.5"
      stroke-linecap="round"
      stroke-linejoin="round"
      class={className}
      aria-hidden="true"
    >
      <path d="M12 3l7 3v6c0 5-3.5 8-7 9-3.5-1-7-4-7-9V6l7-3z" />
      <path d="M9 12l2 2 4-4" />
    </svg>
  )
}
